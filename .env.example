# ============================================================================
# ScheduleWell - Produção (exemplo)
# NÃO usar valores reais neste arquivo. Configure segredos no Coolify.
# ============================================================================

# ─── Backend ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/schedulewell?schema=public
JWT_SECRET=CHANGE_ME_WITH_A_64PLUS_CHAR_RANDOM_SECRET
JWT_EXPIRES_IN=7d
SMTP_HOST=smtp.seu-provedor.com
SMTP_PORT=587
SMTP_USER=no-reply@seu-dominio.com
SMTP_PASS=CHANGE_ME
SMTP_FROM="ScheduleWell <no-reply@seu-dominio.com>"
FRONTEND_URL=https://app.seu-dominio.com
APP_URL=https://app.seu-dominio.com
PORT=3000
NODE_ENV=production

# Segurança e observabilidade
CORS_ORIGINS=https://app.seu-dominio.com
AUTH_RATE_LIMIT=5
ENABLE_SWAGGER=false

# PostgreSQL (quando usar docker-compose)
POSTGRES_DB=schedulewell
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME

# ─── Frontend (Vite) ────────────────────────────────────────────────────────
VITE_API_URL=https://api.seu-dominio.com/api
VITE_APP_NAME=ScheduleWell
