# ─── Banco de dados ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/schedulewell?schema=public"

# ─── Autenticação JWT ────────────────────────────────────────────────────────
# Gere um segredo forte com no mínimo 64 chars aleatórios.
JWT_SECRET="CHANGE_ME_WITH_A_64PLUS_CHAR_RANDOM_SECRET"
JWT_EXPIRES_IN="7d"

# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── CORS / Frontend ─────────────────────────────────────────────────────────
FRONTEND_URL="https://app.seu-dominio.com"
APP_URL="https://app.seu-dominio.com"
CORS_ORIGINS="https://app.seu-dominio.com"

# ─── Rate limit / docs ───────────────────────────────────────────────────────
AUTH_RATE_LIMIT=5
ENABLE_SWAGGER=false

# ─── PostgreSQL (docker-compose.prod.yml) ───────────────────────────────────
POSTGRES_DB=schedulewell
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME

# ─── Notificações / IA (opcional) ────────────────────────────────────────────
REMINDERS_ENABLED="true"
REMINDERS_HOURS_AHEAD="24"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# ─── Email SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.seu-provedor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@seu-dominio.com
SMTP_PASS=CHANGE_ME
SMTP_FROM="ScheduleWell <no-reply@seu-dominio.com>"

